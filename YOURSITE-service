<div class="wrap">
  <div class="card">
    <h1>Thai Consonant Drill</h1>
    <p class="sub">Please enter your name before starting the quiz.</p>

    <!-- Screen 1: Name input only -->
    <div id="nameScreen">
      <div class="start-box">
        <label for="nicknameInput" class="label">Enter your name</label>
        <input
          id="nicknameInput"
          class="input"
          type="text"
          placeholder="Your name"
          maxlength="30"
        />
        <button id="startBtn" class="btn primary" type="button">Start Quiz</button>
        <div id="startMessage" class="small-note"></div>
      </div>
    </div>

    <!-- Screen 2: Quiz -->
    <div id="quizScreen" class="hidden">
      <div class="topbar">
        <div class="pill">
          <span>👤 Player:</span>
          <strong id="playerInfo"></strong>
        </div>
        <div class="pill">
          <span>❤️ Lives:</span>
          <span class="hearts" id="hearts"></span>
        </div>
        <div class="pill"><span>Score:</span> <strong id="score">0</strong></div>
        <div class="pill"><span>Remaining:</span> <strong id="remaining">0</strong></div>
      </div>

      <div class="quiz">
        <div class="prompt">
          <p class="big" id="currentChar">ก</p>
          <p class="question" id="questionText">What is the name of this Thai consonant?</p>
        </div>

        <div class="grid" id="choices"></div>

        <div class="feedback" id="feedback">Choose the correct answer.</div>

        <div class="actions">
          <button class="btn primary" id="nextBtn" type="button" disabled>Next</button>
          <button class="btn danger" id="restartBtn" type="button">Restart</button>
        </div>
      </div>
    </div>
  </div>
</div>
