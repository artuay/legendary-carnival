class ThaiConsonantDrill {
    constructor() {
        this.currentUserName = '';
        this.lives = 3;
        this.currentStreak = 0;
        this.maxStreak = 0;
        this.score = 0;
        this.totalQuestions = 0;
        this.currentQuestionIndex = 0;
        this.gameActive = false;
        this.answered = false;
    }

    init() {
        this.showPage('name-input');
    }

    showPage(pageName) {
        document.querySelectorAll('.page').forEach(page => {
            page.classList.remove('active');
        });
        document.getElementById(pageName).classList.add('active');
    }

    startGame(name) {
        this.currentUserName = name;
        this.lives = 3;
        this.currentStreak = 0;
        this.maxStreak = 0;
        this.score = 0;
        this.totalQuestions = 0;
        this.currentQuestionIndex = 0;
        this.gameActive = true;
        this.answered = false;

        this.showPage('practice');
        this.nextQuestion();
    }

    nextQuestion() {
        if (this.currentQuestionIndex < thaiConsonants.length && this.gameActive) {
            this.answered = false;
            this.totalQuestions = thaiConsonants.length;
            this.displayQuestion();
        } else if (this.gameActive) {
            this.endGame();
        }
    }

    displayQuestion() {
        const consonant = thaiConsonants[this.currentQuestionIndex];
        const question = document.getElementById('question');
        
        // Create wrong options
        let options = [consonant];
        while (options.length < 4) {
            const randomIndex = Math.floor(Math.random() * thaiConsonants.length);
            if (!options.find(opt => opt.symbol === thaiConsonants[randomIndex].symbol)) {
                options.push(thaiConsonants[randomIndex]);
            }
        }

        // Shuffle options
        options = options.sort(() => Math.random() - 0.5);

        question.innerHTML = `
            <div class="question-display">
                <h2>What is this consonant?</h2>
                <div class="consonant">${consonant.symbol}</div>
                <div class="options">
                    ${options.map((opt, index) => `
                        <button class="option" onclick="game.selectAnswer('${opt.name}', '${consonant.name}', this)">
                            ${opt.name}
                        </button>
                    `).join('')}
                </div>
            </div>
        `;

        this.updateStats();
    }

    selectAnswer(selected, correct, element) {
        if (this.answered) return;

        this.answered = true;
        const isCorrect = selected === correct;

        if (isCorrect) {
            element.classList.add('correct');
            this.score++;
            this.currentStreak++;
            if (this.currentStreak > this.maxStreak) {
                this.maxStreak = this.currentStreak;
            }
            document.getElementById('message').innerHTML = '<div class="message correct">✓ Correct!</div>';
        } else {
            element.classList.add('incorrect');
            this.lives--;
            this.currentStreak = 0;
            document.getElementById('message').innerHTML = `<div class="message incorrect">✗ Wrong! It's "${correct}"</div>`;

            if (this.lives <= 0) {
                this.gameActive = false;
            }
        }

        this.updateStats();

        setTimeout(() => {
            this.currentQuestionIndex++;
            if (this.gameActive && this.currentQuestionIndex < thaiConsonants.length) {
                this.nextQuestion();
            } else if (this.gameActive) {
                this.endGame();
            } else {
                this.gameOver();
            }
        }, 1500);
    }

    updateStats() {
        document.getElementById('lives').textContent = this.lives;
        document.getElementById('streak').textContent = this.currentStreak;
        document.getElementById('score').textContent = this.score;
    }

    endGame() {
        const percentage = Math.round((this.score / this.totalQuestions) * 100);
        this.showPage('game-over');
        document.getElementById('game-over-content').innerHTML = `
            <div class="game-over">
                <h2>🎉 Congratulations, ${this.currentUserName}!</h2>
                <div class="final-stats">
                    <p><strong>Score:</strong> ${this.score}/${this.totalQuestions}</p>
                    <p><strong>Accuracy:</strong> ${percentage}%</p>
                    <p><strong>Max Streak:</strong> ${this.maxStreak}</p>
                </div>
                <button onclick="game.init()">Start Over</button>
            </div>
        `;
    }

    gameOver() {
        this.showPage('game-over');
        document.getElementById('game-over-content').innerHTML = `
            <div class="game-over">
                <h2>💔 Game Over, ${this.currentUserName}!</h2>
                <div class="final-stats">
                    <p><strong>Questions Answered:</strong> ${this.currentQuestionIndex}</p>
                    <p><strong>Correct:</strong> ${this.score}</p>
                    <p><strong>Max Streak:</strong> ${this.maxStreak}</p>
                </div>
                <button onclick="game.init()">Try Again</button>
            </div>
        `;
    }
}

const game = new ThaiConsonantDrill();

document.addEventListener('DOMContentLoaded', () => {
    game.init();

    document.getElementById('start-button').addEventListener('click', (e) => {
        e.preventDefault();
        const name = document.getElementById('name-input-field').value.trim();
        if (name) {
            game.startGame(name);
        } else {
            alert('Please enter your name');
        }
    });
});
